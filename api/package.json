{
  "name": "curio-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Curio 백엔드 API — 링크 → AI 요약 카드 → 보드 큐레이션",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint:api": "redocly lint openapi.yaml"
  },
  "dependencies": {
    "@azure/cosmos": "^4.9.3",
    "@azure/identity": "^4.13.1",
    "@copilot-extensions/preview-sdk": "^5.0.1",
    "@mozilla/readability": "^0.5.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsdom": "^24.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
