# ===== Curio 환경변수 템플릿 =====
# 실제 값은 .env 에 저장하세요. (.env 는 .gitignore 로 커밋되지 않습니다)
# 복사: cp .env.example .env

# --- GitHub Copilot SDK ---
# Copilot 접근 권한이 있는 GitHub 토큰.
# 미설정 시 데모 폴백으로 앱이 동작합니다.
# 발급 방법:  gh auth login   실행 후   gh auth token
GITHUB_TOKEN=

# --- Azure OpenAI (Azure AI Foundry · 1순위 모델 레이어) ---
# 두 값(ENDPOINT + DEPLOYMENT)이 모두 있으면 AI 기능이 Azure OpenAI 로 동작합니다(azure provider).
# 미설정 시 GITHUB_TOKEN(github) → 둘 다 없으면 데모(demo) 순으로 폴백합니다.
# 인증은 키리스(관리 ID / 로컬은 az login). 프로덕션 값은 azd 가 Bicep 출력으로 자동 주입합니다.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-21

# --- 백엔드 ---
PORT=7071
NODE_ENV=development

# --- Azure (배포용) ---
AZURE_ENV_NAME=curio
AZURE_LOCATION=eastasia
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=

# --- Cosmos DB (프로덕션, 2차) ---
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DATABASE=curio
COSMOS_CONTAINER=cards
